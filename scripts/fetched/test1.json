/div>\n</div>\n<div class=\"sm-span6 smue-clmn sme-dsbl-margin-left sme-dsbl-margin-right\">\n<div class=\"smue-szp_primary_nav smue-ce-child-detector floatright\"><i class=\"fa fa-bars responsive_bar\" id=\"menu-toggle\" aria-expanded=\"false\"> </i>  <button class=\"menu-toggle\" id=\"menu-toggle\" aria-expanded=\"false\" aria-controls=\"site-navigation social-navigation\">Menu</button>\n\t<div id=\"site-header-menu\" class=\"site-header-menu\">\n\t\t<nav id=\"site-navigation\" class=\"main-navigation\" role=\"navigation\" aria-label=\"Primary Menu\" aria-expanded=\"false\"><div class=\"menu-header-menu-container\"><ul id=\"menu-header-menu\" class=\"primary-menu\"><li id=\"menu-item-10\" class=\"home menu-item menu-item-type-post_type menu-item-object-page menu-item-10\" style=\"  \"><a href=\"../index.html\" style=\"  \">Home</a></li>\n<li id=\"menu-item-12\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-12\" style=\"  \"><a href=\"../contact.html\" style=\"  \">Contact</a></li>\n<li id=\"menu-item-123\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-123\" style=\"  \"><a href=\"../page-4.html\" style=\"  \">USEFUL LINKS</a></li>\n<li id=\"menu-item-87\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-87\" style=\"  \"><a href=\"../page-3.html\" style=\"  \">Q &amp; A</a></li>\n<li id=\"menu-item-128\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-128\" style=\"  \"><a href=\"../page-5.html\" style=\"  \">DOWNLOADS</a></li>\n<li id=\"menu-item-160\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-160\" style=\"  \"><a href=\"../page-7.html\" style=\"  \">Did you know?</a></li>\n<li id=\"menu-item-209\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-209\" style=\"  \"><a href=\"../page-8.html\" style=\"  \">ARTICLES</a></li>\n<li id=\"menu-item-662\" class=\"menu-item menu-item-type-post_type menu-item-object-page menu-item-662\" style=\"  \"><a href=\"../page-9.html\" style=\"  \">URDU ARTICLES</a></li>\n</ul></div></nav><!-- .main-navigation -->\n\t</div><!-- .site-header-menu --></div><style>@media screen and (min-width:768px) { .site-header-menu .main-navigation .primary-menu > li {} .site-header-menu .main-navigation a{ font-family:;} .site-header-menu .main-navigation .sub-menu a {} .site-header-menu .main-navigation .current-menu-item > a {} .site-header-menu .main-navigation li:hover > a {} .site-header-menu .main-navigation .primary-menu > .menu-item-has-children > a::after {} .site-header-menu .main-navigation ul ul .menu-item-has-children > a::after {} } @media screen and (max-width:767px) { .site-header-menu .main-navigation a, .site-header-menu .main-navigation .sub-menu a {} i.responsive_bar{} .site-header-menu .main-navigation li.current-menu-item > a {} .site-header-menu .main-navigation a:hover, .site-header-menu .main-navigation .primary-menu li a:hover {} .site-header-menu {} .dropdown-toggle:after {} }</style><script type=\"text/javascript\">\n\t\t\n\t\tjQuery(document).ready(function(){\n\t\t\t\n\t\t\tvar maxwidth = 0;\n\t\t\tvar menu_len = jQuery(\"div.smue-szp_primary_nav\").length; // number of menus added\n\t\t\t\n\t\t\tjQuery( \"ul.primary-menu > li\" ).each(function() {\n\t\t\t\tmaxwidth += jQuery(this).width(); // Find total width\n\t\t\t});\n\t\t\t\n\t\t\tif(menu_len){\n\t\t\t\tmaxwidth /= menu_len; // Divide the total width with number of menus\n\t\t\t}\n\t\t\t\n\t\t\tjQuery( \".smue-szp_primary_nav\" ).css( \"maxWidth\", maxwidth + \"px\" ); // Assign the maxWidth\n\t\t});\t\t\n\t\t</script>\n</div>\n</div>\n<div class=\"sm-row-fluid smue-row sme-dsbl-margin-left sme-dsbl-margin-right\">\n<div class=\"sm-span12 smue-clmn sme-dsbl-margin-left sme-dsbl-margin-right\">\n<div class=\"smue-image-obj smue-text-align-center\"><img src=\"../images/36_17.png\" title=\"36_17\" alt=\"36_17\" class=\"smue-image-obj-basic sme-dsbl-margin-left sme-dsbl-margin-right sme-dsbl-margin-top sme-dsbl-margin-bottom\"></div>\n</div>\n</div>\n<div class=\"sm-row-fluid smue-row sme-dsbl-margin-left sme-dsbl-margin-right\">\n<div class=\"sm-span12 smue-clmn sme-dsbl-margin-left sme-dsbl-margin-right\">\n<div class=\"smue-text-obj\">\n<h4 style=\"text-align: center;\"><span style=\"color: #ffffff;\">“Clear propagation is our ONLY responsibility”</span> [Surah Yaseen, Aayat 17]</h4>\n</div>\n</div>\n</div>\n</div>\n</div>\n\n\t\t</header><!-- .site-header -->\n\t\t<script language=\"javascript\" type=\"text/javascript\">\n\t\t\tvar cur_page_data = {pageid:\"1147\", pagename:\"bukhaari-shareef-recitation-yet-another-bidah-in-the-making\"};\n\t\t\tvar cur_themes_url = \"http://jamiat.joburg/site-data/themes\";\n\t\t</script>\n\t\t<div id=\"content\" class=\"site-content\">\n\n<div id=\"primary\" class=\"content-area\">\n\t<main id=\"main\" class=\"site-main\" role=\"main\">\n\t\t\n<article id=\"post-1147\" class=\"post-1147 post type-post status-publish format-standard hentry\">\n\t<header class=\"entry-header\">\n\t\t<h1 class=\"entry-title\">BUKHAARI SHAREEF RECITATION? Yet another Bid’ah in the making</h1>\t</header><!-- .entry-header -->\n\n\t\n\t\n\t<div class=\"entry-content\">\n\t\t<div class=\"sm-row-fluid smue-row sme-dsbl-margin-left sme-dsbl-margin-right\">\n<div class=\"sm-span12 smue-clmn  sme-dsbl-margin-left sme-dsbl-margin-right\">\n<div class=\"smue-text-obj\">\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">Allah Ta`ala declares in the Qur’aan Majeed: “<strong><em>On this day have I completed for you your Deen</em></strong>.”</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">It has been reported in Tirmidhi Shareef from Hadhrat Nafi` (rahmatullahi alaih) that a man sneezed in the presence of Ibn Umar (radhiallahu anhu). The man said, “<em>Alhamdulillahi Wassalaamu ala Rasulillah</em>.”</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">Hadhrat Ibn Umar (radhiallahu anhu) commented, “<em>I too acknowledge the praises of Allah Ta`ala and send salutations to Nabi (sallallahu alaihi wasallam), however this is not what Nabi (sallallahu alaihi wasallam) taught us (to say after sneezing). He taught us to say,</em> ‘<em>Alhamdulillah Ala Kulli Haal</em>.’”</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">Our Deen has been completed and perfected by Allah Rabbul Izzat. Any act of Deen which is deemed an Ibaadat that has not been practiced or advocated by Nabi (sallallahu alaihi wasallam) or his Sahaabah or anyone from the Khairul Quroon, is described as an act of Bid`ah. A Bid’ah is simply translated as an ‘innovation’. Any act of worship or Ibaadat that is ‘new’ to our Deen, is a Bid`ah.</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">Imaam Rabbani said, “<em>The case with all bid`ah is the same – that is, they are accretions to the Sunnah thereby displacing it.”</em></span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">A message has been circulating inviting people to a “recitation of Bukhaari Shareef” which is to take place at the Azaadville Darul Uloom Musjid. The message claims: “<em>This has been the action of our pious predecessors that when they were afflicted with some difficulty, they would have a recitation of Bukhaari Shareef…</em>”</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">Whilst we have never heard of such a practice amongst our pious predecessors, it changes nothing if this ever was a practice of some. It remains a Bid`ah.</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">We do acknowledge the blessings and power of the Ahaadith of Nabi (sallallahu alaihi wasallam) and also the <em>barkat</em> of Bukhaari Shareef (and all the other Saheeh Ahaadith Kutub). There may be some (pious predecessors) who have advised that recitation of the entire Kitaab is a means of barkat, but this would apply to individual recitation and never congregational. This bid`ah as advocated by these persons in Azaadville perfectly fits the description of a Bid`ah! When any act of Ibaadat – or simply put, an act which intends to draw the Mercy of Allah Ta`ala, is done by specifying a time and or place for its execution and inviting others to it, which has never been done or taught during the era of Nabi (sallallahu alaihi wasallam) or Khairul Quroon, is branded a BID`AH!</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">The abuse of the Qunoot Naazilah, which has also reached, nay surpassed, the level of Bid`ah, seems to be insufficient for these Ulama.</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">They now crave other means of accreditation or recognition to show people they “care” for the plight of the Palestinians.</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">It is indeed sad that Ulama don’t recognise the plethora of advice from the Qur`aan Majeed and the Sunnah of Nabi (sallallahu alaihi wasallam) to draw the Mercy and Aid of Allah Rabbul Izzat in difficult times upon the Ummah, that they resort to the darkness of Bid`ah. Aggrandizement and <em>Hubbe Jah </em>are the only motives we see in this sad scenario. </span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">The Hadith shows simple remedies to situations like we have in Palestine or in fact any difficulties the Ummah faces:</span></p>\n<p class=\"MsoListParagraph\" style=\"text-align: justify; text-indent: -18.0pt; mso-list: l0 level1 lfo1;\"><!-- &#091;if !supportLists&#093;--><span style=\"font-size: 12.0pt; line-height: 107%; font-family: Symbol; mso-fareast-font-family: Symbol; mso-bidi-font-family: Symbol; color: #08081a; mso-bidi-font-weight: bold; mso-bidi-font-style: italic;\">·<span style=\"font: 7.0pt 'Times New Roman';\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span><!--&#091;endif&#093;--><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin; color: #08081a;\">Hadhrat Sa`ad (radhiallahu anhu) reports that Nabi (sallallahu alaihi wasallam) said: “<strong><em>The supplication of Dhun-Nun (Hadhrat Yunus alaihi salaam) when he supplicated, while in the belly of the whale was </em></strong></span></p>\n<p class=\"MsoNormal\" style=\"text-align: center;\" align=\"center\"><strong><span dir=\"RTL\" lang=\"AR-SA\" style=\"font-size: 14.0pt; line-height: 107%; font-family: 'Traditional Arabic',serif; color: black;\">لاَ إِلَهَ إِلاَّ أَنْتَ سُبْحَانَكَ إِنِّي كُنْتُ مِنَ الظَّالِمِينَ</span></strong></p>\n<p class=\"MsoNormal\" style=\"margin-left: 36.0pt; text-align: justify;\"><strong><em><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin; color: #08081a;\">So indeed, no Muslim supplicates with it for </span></em></strong><strong><em><span style=\"text-decoration: underline;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin; color: red;\">anything, ever</span></span></em></strong><strong><em><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin; color: #08081a;\">, except Allah responds to him.” </span></em></strong><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin; color: #08081a;\">[Tirmidhi Shareef]</span></p>\n<p class=\"MsoListParagraphCxSpFirst\" style=\"text-align: justify; text-indent: -18.0pt; mso-list: l0 level1 lfo1;\"><!-- &#091;if !supportLists&#093;--><span style=\"font-size: 14.0pt; line-height: 107%; font-family: Symbol; mso-fareast-font-family: Symbol; mso-bidi-font-family: Symbol; color: #08081a;\">·<span style=\"font: 7.0pt 'Times New Roman';\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span><!--&#091;endif&#093;--><span style=\"font-size: 12pt; line-height: 107%; color: black; background-image: initial; background-position: initial; background-size: initial; background-repeat: initial; background-attachment: initial; background-origin: initial; background-clip: initial;\">Abu Darda reported: Rasulullah (Sallallahu alaihi wasallam) said, “<strong><em><span style=\"font-family: 'Calibri',sans-serif; mso-ascii-theme-font: minor-latin; mso-hansi-theme-font: minor-latin; mso-bidi-theme-font: minor-latin;\">No Muslim servant supplicates for his brother in his absence but that the angel says: And for you the same</span></em></strong>.”</span></p>\n<p class=\"MsoListParagraphCxSpLast\" style=\"text-align: justify; text-indent: -18.0pt; mso-list: l0 level1 lfo1;\"><!-- &#091;if !supportLists&#093;--><span style=\"font-size: 16.0pt; line-height: 107%; font-family: Symbol; mso-fareast-font-family: Symbol; mso-bidi-font-family: Symbol; color: #08081a; mso-bidi-font-style: italic;\">·<span style=\"font: 7.0pt 'Times New Roman';\">&nbsp;&nbsp;&nbsp;&nbsp;&nbsp; </span></span><!--&#091;endif&#093;--><em><span style=\"font-size: 12pt; line-height: 107%; color: black; background-image: initial; background-position: initial; background-size: initial; background-repeat: initial; background-attachment: initial; background-origin: initial; background-clip: initial;\">Abdullah ibn Amr (radhiallahu anhu) reported: Rasulullah (sallallahu alaihi wasallam) said, “<strong><span style=\"font-family: 'Calibri',sans-serif; mso-ascii-theme-font: minor-latin; mso-hansi-theme-font: minor-latin; mso-bidi-theme-font: minor-latin;\">No supplication is quicker to be answered than a supplication on behalf of one absent.</span></strong>”</span></em></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin; color: #08081a;\">The above are just a few examples of simple remedies prescribed by Nabi (sallallahu alaihi wasallam) that every Muslim can (and should) do in the privacy of their homes for the Palestinians and for the entire Ummah. Just observe the beauty of the Sunnah in that when we make dua for the Palestinians, Allah Ta`ala will grant us the same protection we ask Him for. There is absolutely no Hadith or anything recorded from the life of our beloved Nabi (sallallahu alaihi wasallam) or his Sahaabah (radhiallahu anhum) or Tabieen or Tab`e Taabieen (rahmatullahi alaihim ajmaeen) that advocates or even hints at congregating to recite Ahaadith or make any Thikr or Tilaawat as a means of drawing Allah Ta`ala’s Rahmat. The Hadith mentions the blessings of Surah Yaseen (and other Surahs), but nowhere is it advocated to be recited in congregation or unison. Even in the Qur`aan Majeed, Allah Ta`ala informs us to make dua to Him<strong> in silence </strong>and that it is such duas that He will readily accept.</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin; color: #08081a;\">Today it is one Darul Uloom that gives birth to the accretion and bid`ah of “Buhaari Shareef recitation” and tomorrow we’ll have all the others follow suit. What about those foreign students (of which almost all our Darul Ulooms have a majority of) who will return to their homes and initiate such <em>Bid`aat</em> which they witnessed their <em>Asaatiza </em>peddling? </span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin; color: #08081a;\">Ulama should realise that the only salvation of this Ummah lies in following the Qur`aan Majeed and Sunnah, specifically in matters of Deen. They should be advancing and propagating the practices of the Sunnah, rather than holding to the views of people who came centuries after Khairul Quroon. When the Shariah has all the remedies to whatever ails the Ummah, why then divert to alien practices? As mentioned above by Mujaddid Alfe Thaani – acts of Bid`ah displace the Sunnah.</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin; color: #08081a;\">The incident above where Hadhrat Abdullah Ibn Umar (radhiallahu anhu) acknowledged the virtue of praising Allah Ta`ala and Durood, however its execution and recitation at a time that was not advocated by Nabi (sallallahu alaihi wasallam) rendered it an innovation. It displaced a Sunnah! So even the recitation of something virtuous, when done at an inopportune time and in an inopportune manner meant punishment and not reward.</span></p>\n<p class=\"MsoNormal\" style=\"text-align: justify;\"><span style=\"font-size: 12.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin; color: #08081a;\">The irony of this entire “Bukhari Shareef recitation” Bid`ah is that the Noble Ahaadith Shareef is being (ab)used to displace and replace the Sunnah. Inna Lillahi wa Inna Ilaihi Rajioon!</span></p>\n<p class=\"MsoNormal\" style=\"text-align: center;\" align=\"center\"><strong><em><span style=\"font-size: 13.0pt; line-height: 107%; mso-bidi-font-family: Calibri; mso-bidi-theme-font: minor-latin;\">May Allah Ta`ala guide this Ummah.</span></em></strong></p>\n<p>&nbsp;</p>\n<p class=\"MsoNormal\" style=\"text-align: center;\" align=\"center\"><strong><span style=\"font-size: 12.0pt; line-height: 107%; mso-ascii-font-family: Calibri; mso-hansi-font-family: Calibri; mso-bidi-font-family: Calibri;\">“<em>Clear propagation is our ONLY responsibility”</em></span></strong></p>\n</div>\n</div>\n</div>\n\t</div><!-- .entry-content -->\n\n\t<footer class=\"entry-footer\">\n\t\t<span class=\"byline\"><span class=\"author vcard\"><img alt=\"\" src=\"http://2.gravatar.com/avatar/2a292f79de62ec98417064d4a4611884?s=49&amp;d=mm&amp;r=g\" srcset=\"http://2.gravatar.com/avatar/2a292f79de62ec98417064d4a4611884?s=98&amp;d=mm&amp;r=g 2x\" class=\"avatar avatar-49 photo\" height=\"49\" width=\"49\"><span class=\"screen-reader-text\">Author </span> <span style=\"font-size: 15px; cursor:pointer\">ayugqoxu</span></span></span><span class=\"posted-on\"><i class=\"fa fa-calendar\" aria-hidden=\"true\"></i><span class=\"screen-reader-text\">Posted on </span><a href=\"../blog/bukhaari-shareef-recitation-yet-another-bidah-in-the-making.html\" rel=\"bookmark\"><time class=\"entry-date published updated\" datetime=\"2025-06-23T12:02:34+00:00\">June 23, 2025</time></a></span>\t\t\t</footer><!-- .entry-footer -->\n</article><!-- #post-## -->\n\n\t<nav class=\"navigation post-navigation\" role=\"navigation\">\n\t\t<h2 class=\"screen-reader-text\">Post navigation</h2>\n\t\t<div class=\"nav-links\"><div class=\"nav-previous\"><a href=\"../blog/using-the-miswaak-immediately-before-commencing-salaat-dispelling-a-misconception.html\" rel=\"prev\"><span class=\"meta-nav\" aria-hidden=\"true\">Previous</span> <span class=\"screen-reader-text\">Previous post:</span> <span class=\"post-title\">USING THE MISWAAK IMMEDIATELY BEFORE COMMENCING SALAAT – DISPELLING A MISCONCEPTION</span></a></div></div>\n\t</nav>\n\t</main><!-- .site-main -->\n\n</div><!-- .content-area -->\n\n\n\t\t</div><!-- .site-content -->\n\t\t\n\t\t\n\t\t<footer id=\"colophon\" class=\"site-footer\" role=\"contentinfo\"><div class=\"sm-row-fluid smue-row sme-dsbl-margin-left sme-dsbl-margin-right footer\">\n<div class=\"sm-span6 smue-clmn  sme-dsbl-margin-left sme-dsbl-margin-right\">\n<div class=\"smue-text-obj\">\n<p style=\"text-align: left;\"><strong><span style=\"color: #ffffff;\">Jamiatul Ulama (Johannesburg)</span></strong></p>\n<p style=\"text-align: left;\"><strong><span style=\"color: #ffffff;\">P. O. Box</span></strong><strong><span style=\"color: #ffffff;\">&nbsp;961195</span></strong></p>\n<p style=\"text-align: left;\"><strong><span style=\"color: #ffffff;\">Brixton,</span></strong><strong><span style=\"color: #ffffff;\">&nbsp;2019, Johannesburg</span></strong></p>\n<p style=\"text-align: left;\"><strong><span style=\"color: #ffffff;\">S</span></strong><strong><span style=\"color: #ffffff;\">OUTH AFRICA</span></strong></p>\n</div>\n</div>\n<div class=\"sm-span6 smue-clmn  sme-dsbl-margin-left sme-dsbl-margin-right\">\n<div class=\"smue-text-obj\">\n<p style=\"text-align: right;\"><strong><span style=\"color: #ffffff;\"><span style=\"color: #ff0000;\">&nbsp;Fax:</span> 0865 777 786</span></strong></p>\n<p style=\"text-align: right;\"><strong><span style=\"color: #ffffff;\"><span style=\"color: #ff0000;\">Whatsapp (Q &amp; A ONLY – No calls, please):</span> +27 786 786 713&nbsp;</span></strong></p>\n<p style=\"text-align: right;\"><strong><span style=\"color: #ffffff;\"><span style=\"color: #ff0000;\">email #1:</span>&nbsp; &nbsp;admin@jamiat.joburg</span></strong></p>\n<p style=\"text-align: right;\"><strong><span style=\"color: #ffffff;\"><span style=\"color: #ffffff;\"><span style=\"color: #ff0000;\">email #2:</span> jamiat.joburg@gmail.com</span></span></strong></p>\n</div>\n</div>\n</div>\n\n\t\t</footer><!-- .site-footer -->\t</div><!-- .site-inner -->\n</div><!-- .site -->\n\n<script type=\"text/javascript\" src=\"../js/skip-link-focus-fix.js\"></script>\n<script type=\"text/javascript\" src=\"../js/comment-reply.min.js\"></script>\n<script type=\"text/javascript\">\n/* <![CDATA[ */\nvar screenReaderText = {\"expand\":\"expand child menu\",\"collapse\":\"collapse child menu\"};\n/* ]]> */\n</script>\n<script type=\"text/javascript\" src=\"../js/functions.js\"></script>\n<script type=\"text/javascript\" src=\"../js/szp-embed.min.js\"></script>\n<script type=\"text/javascript\" src=\"../js/jquery.stellar.min.js\"></script>\n<style id=\"smue-ce-private-styles\" data-posts=\"\" type=\"text/css\"></style>\n</body></html>",
