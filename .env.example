# ============================================================================
# Jamiatul Ulama Johannesburg — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite database file path (relative to project root).
# For Vercel deployment, this must be a relative path: file:./db/custom.db
DATABASE_URL=file:./db/custom.db

# ─── Authentication ──────────────────────────────────────────────────────────
# NextAuth secret — generate with: openssl rand -base64 32
# This is REQUIRED for production. In development, a fallback is used.
NEXTAUTH_SECRET=your-nextauth-secret-here

# NextAuth URL — set to your production domain (e.g. https://jamiat.joburg)
# For local dev, this can be http://localhost:3000
NEXTAUTH_URL=http://localhost:3000

# Trust the host header (required behind proxies like Vercel)
NEXTAUTH_TRUST_HOST=true

# ─── Vercel Deployment ───────────────────────────────────────────────────────
# These are set automatically by Vercel and do not need to be in .env:
#   - NEXTAUTH_SECRET: Set in Vercel Dashboard → Settings → Environment Variables
#   - NEXTAUTH_URL: Set automatically to the deployment URL
#   - DATABASE_URL: Set in vercel.json (file:./db/custom.db)