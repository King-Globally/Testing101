# ============================================================================
# Jamiatul Ulama Johannesburg — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
#   cp .env.example .env
# ============================================================================

# ─── Database ────────────────────────────────────────────────────────────────
# PostgreSQL connection string (Neon.tech serverless recommended for production).
# Get one free at https://neon.tech
DATABASE_URL=postgresql://username:password@ep-your-endpoint.eu-west-2.aws.neon.tech/neondb?sslmode=require

# ─── Authentication ──────────────────────────────────────────────────────────
# NextAuth secret — generate with: openssl rand -base64 32
# This is REQUIRED for production.
NEXTAUTH_SECRET=your-nextauth-secret-here

# NextAuth URL — set to your production domain (e.g. https://jamiat.joburg)
NEXTAUTH_URL=http://localhost:3000

# Trust the host header (required behind proxies like Vercel)
NEXTAUTH_TRUST_HOST=true

# ─── Vercel Deployment ───────────────────────────────────────────────────────
# These are set in Vercel Dashboard → Settings → Environment Variables:
#   - DATABASE_URL: Your Neon.tech PostgreSQL connection string
#   - NEXTAUTH_SECRET: Random base64 string
#   - NEXTAUTH_URL: Your Vercel deployment URL
#   - NEXTAUTH_TRUST_HOST: true